{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forensic Engine",
  "version": "0.5.4",
  "identifier": "app.forensic-engine",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Forensic Engine",
        "width": 1200,
        "height": 860,
        "resizable": true,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/engine-server"]
  }
}
