{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    { "identifier": "shell:allow-execute", "allow": [ { "name": "binaries/forensic-engine", "sidecar": true, "args": true } ] }
  ]
}
